# Database URL - set to your Postgres connection string
# For Vercel Postgres / Neon, this will be provided as POSTGRES_PRISMA_URL or DATABASE_URL
# For local development, point to a local PostgreSQL instance
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hotel_tracker"

# Set to "true" to show detailed error messages in the UI (do NOT enable in production)
# NEXT_PUBLIC_DEBUG="true"

# Database URL for functional/E2E tests
DATABASE_URL_TEST="postgresql://postgres:postgres@localhost:5432/hotel_tracker_test"

# Auth.js secret (generate with: openssl rand -base64 32)
AUTH_SECRET="your-secret-here"

# Google Places API key (https://console.cloud.google.com — ~$200/month free credit)
# Enable "Places API (New)" in your Google Cloud project, then create an API key.
# Restrict the key to the "Places API (New)" to limit exposure.
GOOGLE_PLACES_API_KEY="your-google-places-api-key"

# Seed admin user credentials
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="change-me-in-production"

# Cron job authentication (generate with: openssl rand -base64 32)
# Also add as a GitHub repository secret (CRON_SECRET) for the GH Actions price watch workflow
CRON_SECRET="your-cron-secret-here"

# ── Price Watch ────────────────────────────────────────────────────────────────


# Resend (https://resend.com) — for price drop email alerts
# Free tier: use onboarding@resend.dev as FROM to send to your own email only
# For custom domains: verify your domain in Resend and use an address on that domain
RESEND_API_KEY="re_your-api-key-here"
RESEND_FROM_EMAIL="onboarding@resend.dev"
