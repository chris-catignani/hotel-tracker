generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PointCategory {
  hotel
  airline
  transferable
}

enum Refundability {
  REFUNDABLE
  NON_REFUNDABLE
  UNKNOWN
}

enum UserRole {
  USER
  ADMIN
}

enum BenefitPeriod {
  monthly
  quarterly
  semi_annual
  annual
}

enum BookingSourceType {
  direct_web
  direct_app
  ota
  other
}

enum CertType {
  marriott_35k
  marriott_40k
  marriott_50k
  marriott_85k
  hyatt_cat1_4
  hyatt_cat1_7
  ihg_40k
}

enum BenefitType {
  free_breakfast
  dining_credit
  spa_credit
  room_upgrade
  late_checkout
  early_checkin
  other
}

enum BenefitPointsEarnType {
  fixed_per_stay
  fixed_per_night
  multiplier_on_base
}

enum AccommodationType {
  hotel
  apartment
}

enum PaymentTiming {
  prepaid // charged at booking date (e.g. OTA portal bookings)
  postpaid // charged at check-in (e.g. direct hotel bookings)
}

enum CreditCardRewardRuleType {
  multiplier
  fixed
}

enum SubBrandRestrictionMode {
  include
  exclude
}

enum IngestionMethod {
  manual
  email
}

enum PostingStatus {
  pending
  posted
  failed
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  password      String?
  role          UserRole  @default(USER)
  createdAt     DateTime  @default(now()) @map("created_at")
  accounts      Account[]
  sessions      Session[]
  bookings        Booking[]
  promotions      Promotion[]
  userStatuses    UserStatus[]
  userPromotions  UserPromotion[]
  priceWatches    PriceWatch[]
  userCreditCards UserCreditCard[]
  userPartnershipEarns UserPartnershipEarn[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model PointType {
  id                   String           @id @default(cuid())
  name                 String
  category             PointCategory
  usdCentsPerPoint     Decimal          @map("usd_cents_per_point") @db.Decimal(10, 6)
  programCurrency      String?          @map("program_currency")
  programCentsPerPoint Decimal?         @map("program_cents_per_point") @db.Decimal(10, 6)
  hotelChains          HotelChain[]
  creditCards          CreditCard[]
  shoppingPortals      ShoppingPortal[]
  partnershipEarns     PartnershipEarn[]

  @@map("point_types")
}

model HotelChain {
  id                    String                  @id @default(cuid())
  name                  String
  loyaltyProgram        String?                 @map("loyalty_program")
  basePointRate         Decimal?                @map("base_point_rate") @db.Decimal(10, 4)
  calculationCurrency   String                  @default("USD") @map("calculation_currency")
  pointTypeId           String?                 @map("point_type_id")
  pointType             PointType?              @relation(fields: [pointTypeId], references: [id])
  bookings              Booking[]
  promotions            Promotion[]
  hotelChainSubBrands   HotelChainSubBrand[]
  eliteStatuses         HotelChainEliteStatus[]
  userStatuses          UserStatus[]
  creditCardRewardRules CreditCardRewardRule[]
  cardBenefits          CardBenefit[]
  promotionRestrictions PromotionRestrictions[]
  properties            Property[]
  partnershipEarns      PartnershipEarn[]

  @@map("hotel_chains")
}

model HotelChainSubBrand {
  id                   String                        @id @default(cuid())
  hotelChainId         String                        @map("hotel_chain_id")
  hotelChain           HotelChain                    @relation(fields: [hotelChainId], references: [id], onDelete: Cascade)
  name                 String
  basePointRate        Decimal?                      @map("base_point_rate") @db.Decimal(10, 4)
  bookings             Booking[]
  subBrandRestrictions PromotionSubBrandRestriction[]

  @@unique([hotelChainId, name])
  @@map("hotel_chain_sub_brands")
}

model HotelChainEliteStatus {
  id              String       @id @default(cuid())
  hotelChainId    String       @map("hotel_chain_id")
  hotelChain      HotelChain   @relation(fields: [hotelChainId], references: [id], onDelete: Cascade)
  name            String
  eliteTierLevel  Int          @default(0) @map("elite_tier_level")
  bonusPercentage Decimal?     @map("bonus_percentage") @db.Decimal(10, 4) // e.g. 0.50 for 50%
  fixedRate       Decimal?     @map("fixed_rate") @db.Decimal(10, 4) // e.g. 7.0 for 7 points/$1
  isFixed         Boolean      @default(false) @map("is_fixed")
  pointsFloorTo   Int?         @map("points_floor_to") // floor earned points to nearest N (e.g. 100 for GHA); null = Math.round
  userStatuses    UserStatus[]

  @@unique([hotelChainId, name])
  @@map("hotel_chain_elite_statuses")
}

model UserStatus {
  id            String                 @id @default(cuid())
  userId        String                 @map("user_id")
  user          User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  hotelChainId  String                 @map("hotel_chain_id")
  hotelChain    HotelChain             @relation(fields: [hotelChainId], references: [id], onDelete: Cascade)
  eliteStatusId String?                @map("elite_status_id")
  eliteStatus   HotelChainEliteStatus? @relation(fields: [eliteStatusId], references: [id])

  @@unique([userId, hotelChainId])
  @@map("user_statuses")
}

model UserCreditCard {
  id           String     @id @default(cuid())
  userId       String     @map("user_id")
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  creditCardId String     @map("credit_card_id")
  creditCard   CreditCard @relation(fields: [creditCardId], references: [id])
  nickname     String? // e.g. "AMEX Biz Plat #1" — optional, used when multiple instances exist
  openedDate   DateTime?  @db.Date @map("opened_date")
  closedDate   DateTime?  @db.Date @map("closed_date")
  createdAt    DateTime   @default(now()) @map("created_at")

  bookings Booking[]

  @@map("user_credit_cards")
}

model CreditCard {
  id                    String                        @id @default(cuid())
  name                  String
  rewardType            String                        @map("reward_type") // "points" or "cashback"
  rewardRate            Decimal                       @map("reward_rate") @db.Decimal(10, 4) // e.g. 0.05 for 5x
  pointTypeId           String?                       @map("point_type_id")
  pointType             PointType?                    @relation(fields: [pointTypeId], references: [id])
  isDeleted             Boolean                       @default(false) @map("is_deleted")
  rewardRules           CreditCardRewardRule[]
  cardBenefits          CardBenefit[]
  userCreditCards       UserCreditCard[]
  promotions            Promotion[]                   @relation("PromotionCreditCard")
  restrictionTieInCards PromotionRestrictionTieInCard[]

  @@map("credit_cards")
}

model ShoppingPortal {
  id          String      @id @default(cuid())
  name        String
  rewardType  String      @default("cashback") @map("reward_type")
  pointTypeId String?     @map("point_type_id")
  pointType   PointType?  @relation(fields: [pointTypeId], references: [id])
  bookings    Booking[]
  promotions  Promotion[]

  @@map("shopping_portals")
}

model OtaAgency {
  id                    String                 @id @default(cuid())
  name                  String
  bookings              Booking[]
  creditCardRewardRules CreditCardRewardRule[]
  cardBenefits          CardBenefitOtaAgency[]

  @@map("ota_agencies")
}

model Booking {
  id                    String               @id @default(cuid())
  userId                String               @map("user_id")
  user                  User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  hotelChainId          String?              @map("hotel_chain_id")
  hotelChain            HotelChain?          @relation(fields: [hotelChainId], references: [id])
  accommodationType     AccommodationType    @default(hotel) @map("accommodation_type")
  hotelChainSubBrandId  String?              @map("hotel_chain_sub_brand_id")
  hotelChainSubBrand    HotelChainSubBrand?  @relation(fields: [hotelChainSubBrandId], references: [id])
  propertyId            String               @map("property_id")
  property              Property             @relation(fields: [propertyId], references: [id])
  checkIn               DateTime             @map("check_in") @db.Date
  checkOut              DateTime             @map("check_out") @db.Date
  numNights             Int                  @map("num_nights")
  pretaxCost            Decimal              @map("pretax_cost") @db.Decimal(10, 2)
  taxAmount             Decimal              @map("tax_amount") @db.Decimal(10, 2)
  totalCost             Decimal              @map("total_cost") @db.Decimal(10, 2)
  userCreditCardId      String?              @map("user_credit_card_id")
  userCreditCard        UserCreditCard?      @relation(fields: [userCreditCardId], references: [id])
  bookingDate           DateTime?            @db.Date @map("booking_date")
  paymentTiming         PaymentTiming        @default(postpaid) @map("payment_timing")
  shoppingPortalId      String?              @map("shopping_portal_id")
  shoppingPortal        ShoppingPortal?      @relation(fields: [shoppingPortalId], references: [id])
  portalCashbackRate    Decimal?             @map("portal_cashback_rate") @db.Decimal(10, 4)
  portalCashbackOnTotal Boolean              @default(false) @map("portal_cashback_on_total")
  loyaltyPointsEarned   Int?                 @map("loyalty_points_earned")
  pointsRedeemed        Int?                 @map("points_redeemed")
  currency              String               @default("USD")
  lockedExchangeRate            Decimal?             @map("locked_exchange_rate") @db.Decimal(12, 6)
  lockedLoyaltyUsdCentsPerPoint Decimal?             @map("locked_loyalty_usd_cents_per_point") @db.Decimal(10, 6)
  bookingSource         BookingSourceType?   @map("booking_source")
  otaAgencyId           String?              @map("ota_agency_id")
  otaAgency             OtaAgency?           @relation(fields: [otaAgencyId], references: [id])
  notes                 String?
  confirmationNumber    String?              @map("confirmation_number")
  ingestionMethod       IngestionMethod      @default(manual) @map("ingestion_method")
  needsReview           Boolean              @default(false)  @map("needs_review")
  loyaltyPostingStatus     PostingStatus? @map("loyalty_posting_status")
  cardRewardPostingStatus  PostingStatus? @map("card_reward_posting_status")
  portalCashbackPostingStatus PostingStatus? @map("portal_cashback_posting_status")
  createdAt             DateTime             @default(now()) @map("created_at")
  bookingPromotions     BookingPromotion[]
  bookingCardBenefits   BookingCardBenefit[]
  certificates          BookingCertificate[]
  benefits              BookingBenefit[]
  priceWatchBooking     PriceWatchBooking?
  bookingPartnershipEarnStatuses BookingPartnershipEarnStatus[]

  @@index([checkIn])
  @@index([createdAt])
  @@map("bookings")
}

model BookingBenefit {
  id          String      @id @default(cuid())
  bookingId   String      @map("booking_id")
  benefitType BenefitType @map("benefit_type")
  label       String?
  dollarValue      Decimal?               @map("dollar_value") @db.Decimal(10, 2)
  pointsEarnType   BenefitPointsEarnType? @map("points_earn_type")
  pointsAmount     Int?                   @map("points_amount")
  pointsMultiplier Decimal?               @map("points_multiplier") @db.Decimal(6, 3)
  postingStatus    PostingStatus          @default(pending) @map("posting_status")
  booking          Booking                @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("booking_benefits")
}

model BookingCertificate {
  id        String   @id @default(cuid())
  bookingId String   @map("booking_id")
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  certType  CertType @map("cert_type")

  @@map("booking_certificates")
}

enum PromotionType {
  credit_card
  portal
  loyalty
}

enum PromotionRewardType {
  points
  cashback
  certificate
  eqn
}

enum PromotionBenefitValueType {
  fixed
  percentage
  multiplier
}

enum PointsMultiplierBasis {
  base_only
  base_and_elite
}

model PromotionRestrictions {
  id                         String                        @id @default(cuid())
  minSpend                   Decimal?                      @map("min_spend") @db.Decimal(10, 2)
  minNightsRequired          Int?                          @map("min_nights_required")
  nightsStackable            Boolean                       @default(false) @map("nights_stackable")
  spanStays                  Boolean                       @default(false) @map("span_stays")
  maxStayCount               Int?                          @map("max_stay_count")
  maxRewardCount             Int?                          @map("max_reward_count")
  maxRedemptionValue         Decimal?                      @map("max_redemption_value") @db.Decimal(10, 2)
  maxTotalBonusPoints        Int?                          @map("max_total_bonus_points")
  oncePerSubBrand            Boolean                       @default(false) @map("once_per_sub_brand")
  bookByDate                 DateTime?                     @map("book_by_date") @db.Date
  registrationDeadline       DateTime?                     @map("registration_deadline") @db.Date
  validDaysAfterRegistration Int?                          @map("valid_days_after_registration")
  tieInRequiresPayment       Boolean                       @default(false) @map("tie_in_requires_payment")
  allowedPaymentTypes        String[]                      @default([]) @map("allowed_payment_types")
  allowedBookingSources      String[]                      @default([]) @map("allowed_booking_sources")
  allowedCountryCodes        String[]                      @default([]) @map("allowed_country_codes")
  allowedAccommodationTypes  AccommodationType[]           @default([]) @map("allowed_accommodation_types")
  hotelChainId               String?                       @map("hotel_chain_id")
  hotelChain                 HotelChain?                   @relation(fields: [hotelChainId], references: [id])
  prerequisiteStayCount      Int?                          @map("prerequisite_stay_count")
  prerequisiteNightCount     Int?                          @map("prerequisite_night_count")
  subBrandRestrictions       PromotionSubBrandRestriction[]
  tieInCards                 PromotionRestrictionTieInCard[]
  // Exactly one of these is set
  promotion                  Promotion?
  promotionBenefit           PromotionBenefit?

  @@map("promotion_restrictions")
}

model PromotionSubBrandRestriction {
  id                      String                  @id @default(cuid())
  promotionRestrictionsId String                  @map("promotion_restrictions_id")
  promotionRestrictions   PromotionRestrictions   @relation(fields: [promotionRestrictionsId], references: [id], onDelete: Cascade)
  hotelChainSubBrandId    String                  @map("hotel_chain_sub_brand_id")
  hotelChainSubBrand      HotelChainSubBrand      @relation(fields: [hotelChainSubBrandId], references: [id])
  mode                    SubBrandRestrictionMode

  @@unique([promotionRestrictionsId, hotelChainSubBrandId])
  @@map("promotion_sub_brand_restrictions")
}

model PromotionRestrictionTieInCard {
  id                      String                @id @default(cuid())
  promotionRestrictionsId String                @map("promotion_restrictions_id")
  promotionRestrictions   PromotionRestrictions @relation(fields: [promotionRestrictionsId], references: [id], onDelete: Cascade)
  creditCardId            String                @map("credit_card_id")
  creditCard              CreditCard            @relation(fields: [creditCardId], references: [id])

  @@unique([promotionRestrictionsId, creditCardId])
  @@map("promotion_restriction_tie_in_cards")
}

model Promotion {
  id               String                 @id @default(cuid())
  userId           String                 @map("user_id")
  user             User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  name             String
  type             PromotionType
  hotelChainId     String?                @map("hotel_chain_id")
  hotelChain       HotelChain?            @relation(fields: [hotelChainId], references: [id])
  creditCardId     String?                @map("credit_card_id")
  creditCard       CreditCard?            @relation("PromotionCreditCard", fields: [creditCardId], references: [id])
  shoppingPortalId String?                @map("shopping_portal_id")
  shoppingPortal   ShoppingPortal?        @relation(fields: [shoppingPortalId], references: [id])
  startDate        DateTime?              @map("start_date") @db.Date
  endDate          DateTime?              @map("end_date") @db.Date
  createdAt        DateTime               @default(now()) @map("created_at")
  restrictionsId   String?                @unique @map("restrictions_id")
  restrictions     PromotionRestrictions? @relation(fields: [restrictionsId], references: [id])
  benefits         PromotionBenefit[]
  tiers            PromotionTier[]
  bookingPromotions BookingPromotion[]
  userPromotions   UserPromotion?

  @@map("promotions")
}

model UserPromotion {
  id               String    @id @default(cuid())
  userId           String    @map("user_id")
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  promotionId      String    @unique @map("promotion_id")
  registrationDate DateTime  @map("registration_date") @db.Date
  promotion        Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)

  @@map("user_promotions")
}

model PromotionTier {
  id          String             @id @default(cuid())
  promotionId String             @map("promotion_id")
  minStays    Int?               @map("min_stays")
  maxStays    Int?               @map("max_stays")
  minNights   Int?               @map("min_nights")
  maxNights   Int?               @map("max_nights")
  promotion   Promotion          @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  benefits    PromotionBenefit[]

  @@map("promotion_tiers")
}

model PromotionBenefit {
  id                       String                    @id @default(cuid())
  promotionId              String?                   @map("promotion_id")
  promotion                Promotion?                @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  promotionTierId          String?                   @map("promotion_tier_id")
  promotionTier            PromotionTier?            @relation(fields: [promotionTierId], references: [id], onDelete: Cascade)
  rewardType               PromotionRewardType       @map("reward_type")
  valueType                PromotionBenefitValueType @map("value_type")
  value                    Decimal                   @db.Decimal(10, 4)
  certType                 String?                   @map("cert_type")
  pointsMultiplierBasis    PointsMultiplierBasis?    @default(base_only) @map("points_multiplier_basis")
  sortOrder                Int                       @default(0) @map("sort_order")
  createdAt                DateTime                  @default(now()) @map("created_at")
  restrictionsId           String?                   @unique @map("restrictions_id")
  restrictions             PromotionRestrictions?    @relation(fields: [restrictionsId], references: [id])
  bookingPromotionBenefits BookingPromotionBenefit[]

  @@map("promotion_benefits")
}

model BookingPromotion {
  id                  String                    @id @default(cuid())
  bookingId           String                    @map("booking_id")
  booking             Booking                   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  promotionId         String                    @map("promotion_id")
  promotion           Promotion                 @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  appliedValue        Decimal                   @map("applied_value") @db.Decimal(10, 2)
  bonusPointsApplied  Int?                      @map("bonus_points_applied")
  isOrphaned          Boolean                   @default(false) @map("is_orphaned")
  isPreQualifying     Boolean                   @default(false) @map("is_pre_qualifying")
  autoApplied         Boolean                   @default(true) @map("auto_applied")
  postingStatus       PostingStatus             @default(pending) @map("posting_status")
  eligibleNightsAtBooking Int?                  @map("eligible_nights_at_booking")
  benefitApplications BookingPromotionBenefit[]

  @@map("booking_promotions")
}

model BookingPromotionBenefit {
  id                 String           @id @default(cuid())
  bookingPromotionId String           @map("booking_promotion_id")
  bookingPromotion   BookingPromotion @relation(fields: [bookingPromotionId], references: [id], onDelete: Cascade)
  promotionBenefitId String           @map("promotion_benefit_id")
  promotionBenefit   PromotionBenefit @relation(fields: [promotionBenefitId], references: [id], onDelete: Cascade)
  appliedValue       Decimal          @map("applied_value") @db.Decimal(10, 2)
  bonusPointsApplied Int?             @map("bonus_points_applied")
  isOrphaned         Boolean          @default(false) @map("is_orphaned")
  isPreQualifying    Boolean          @default(false) @map("is_pre_qualifying")
  eligibleNightsAtBooking Int?        @map("eligible_nights_at_booking")

  @@map("booking_promotion_benefits")
}

model PartnershipEarn {
  id           String     @id @default(cuid())
  name         String
  hotelChainId String?    @map("hotel_chain_id")
  pointTypeId  String     @map("point_type_id")
  earnRate     Decimal    @map("earn_rate") @db.Decimal(10, 4)
  earnCurrency String     @map("earn_currency")
  countryCodes String[]   @default([]) @map("country_codes")
  isActive     Boolean    @default(true) @map("is_active")

  hotelChain HotelChain?           @relation(fields: [hotelChainId], references: [id])
  pointType  PointType             @relation(fields: [pointTypeId], references: [id])
  userEarns  UserPartnershipEarn[]
  bookingPartnershipEarnStatuses BookingPartnershipEarnStatus[]

  @@map("partnership_earns")
}

model UserPartnershipEarn {
  id                String          @id @default(cuid())
  userId            String          @map("user_id")
  partnershipEarnId String          @map("partnership_earn_id")
  isEnabled         Boolean         @default(false) @map("is_enabled")

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  partnershipEarn PartnershipEarn @relation(fields: [partnershipEarnId], references: [id], onDelete: Cascade)

  @@unique([userId, partnershipEarnId])
  @@map("user_partnership_earns")
}

model ExchangeRate {
  id           Int      @id @default(autoincrement())
  fromCurrency String   @map("from_currency")
  toCurrency   String   @map("to_currency")
  rate         Decimal  @db.Decimal(12, 6)
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([fromCurrency, toCurrency])
  @@map("exchange_rates")
}

model ExchangeRateHistory {
  id           Int      @id @default(autoincrement())
  fromCurrency String   @map("from_currency")
  toCurrency   String   @map("to_currency")
  date         DateTime @db.Date
  rate         Decimal  @db.Decimal(12, 6)

  @@unique([fromCurrency, toCurrency, date])
  @@map("exchange_rate_history")
}

model GeoCache {
  id         Int      @id @default(autoincrement())
  queryKey   String   @unique @map("query_key")
  results    Json
  resolvedAt DateTime @default(now()) @map("resolved_at")

  @@map("geo_cache")
}

model CreditCardRewardRule {
  id           String                   @id @default(cuid())
  creditCardId String                   @map("credit_card_id")
  creditCard   CreditCard               @relation(fields: [creditCardId], references: [id], onDelete: Cascade)
  hotelChainId String?                  @map("hotel_chain_id")
  hotelChain   HotelChain?              @relation(fields: [hotelChainId], references: [id], onDelete: SetNull)
  otaAgencyId  String?                  @map("ota_agency_id")
  otaAgency    OtaAgency?               @relation(fields: [otaAgencyId], references: [id], onDelete: SetNull)
  rewardType   CreditCardRewardRuleType @map("reward_type")
  rewardValue  Decimal                  @map("reward_value") @db.Decimal(10, 4)
  createdAt    DateTime                 @default(now()) @map("created_at")

  @@map("credit_card_reward_rules")
}

model CardBenefit {
  id                 String        @id @default(cuid())
  creditCardId       String        @map("credit_card_id")
  creditCard         CreditCard    @relation(fields: [creditCardId], references: [id], onDelete: Cascade)
  description        String
  value              Decimal       @db.Decimal(10, 2)
  maxValuePerBooking Decimal?      @map("max_value_per_booking") @db.Decimal(10, 2)
  period             BenefitPeriod
  hotelChainId       String?       @map("hotel_chain_id")
  hotelChain         HotelChain?   @relation(fields: [hotelChainId], references: [id], onDelete: SetNull)
  isActive           Boolean       @default(true) @map("is_active")
  startDate          DateTime?     @map("start_date")
  endDate            DateTime?     @map("end_date")
  createdAt          DateTime      @default(now()) @map("created_at")

  bookingCardBenefits BookingCardBenefit[]
  otaAgencies         CardBenefitOtaAgency[]

  @@map("card_benefits")
}

model CardBenefitOtaAgency {
  cardBenefitId String      @map("card_benefit_id")
  cardBenefit   CardBenefit @relation(fields: [cardBenefitId], references: [id], onDelete: Cascade)
  otaAgencyId   String      @map("ota_agency_id")
  otaAgency     OtaAgency   @relation(fields: [otaAgencyId], references: [id], onDelete: Cascade)

  @@id([cardBenefitId, otaAgencyId])
  @@map("card_benefit_ota_agencies")
}

model BookingCardBenefit {
  id            String        @id @default(cuid())
  bookingId     String        @map("booking_id")
  booking       Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  cardBenefitId String        @map("card_benefit_id")
  cardBenefit   CardBenefit   @relation(fields: [cardBenefitId], references: [id], onDelete: Cascade)
  appliedValue  Decimal       @map("applied_value") @db.Decimal(10, 2)
  periodKey     String        @map("period_key")
  postingStatus PostingStatus @default(pending) @map("posting_status")

  @@unique([bookingId, cardBenefitId])
  @@map("booking_card_benefits")
}

model Property {
  id              String      @id @default(cuid())
  name            String
  placeId         String?     @unique @map("place_id")
  chainPropertyId String?     @map("chain_property_id") // spiritCode for Hyatt, Amadeus ID for others
  hotelChainId    String?     @map("hotel_chain_id")
  hotelChain      HotelChain? @relation(fields: [hotelChainId], references: [id])
  countryCode     String?     @map("country_code")
  city            String?
  address         String?
  latitude        Float?
  longitude       Float?
  starRating      Float?      @map("star_rating")
  createdAt       DateTime    @default(now()) @map("created_at")
  bookings     Booking[]
  priceWatches PriceWatch[]

  @@unique([name, hotelChainId])
  @@map("properties")
}

model BookingPartnershipEarnStatus {
  id                String          @id @default(cuid())
  bookingId         String          @map("booking_id")
  booking           Booking         @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  partnershipEarnId String          @map("partnership_earn_id")
  partnershipEarn   PartnershipEarn @relation(fields: [partnershipEarnId], references: [id], onDelete: Cascade)
  postingStatus     PostingStatus   @default(pending) @map("posting_status")

  @@unique([bookingId, partnershipEarnId])
  @@map("booking_partnership_earn_statuses")
}

model PriceWatch {
  id            String              @id @default(cuid())
  userId        String              @map("user_id")
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  propertyId    String              @map("property_id")
  property      Property            @relation(fields: [propertyId], references: [id])
  isEnabled     Boolean             @default(true) @map("is_enabled")
  lastCheckedAt DateTime?           @map("last_checked_at")
  createdAt     DateTime            @default(now()) @map("created_at")
  bookings      PriceWatchBooking[]
  snapshots     PriceSnapshot[]

  @@unique([userId, propertyId])
  @@map("price_watches")
}

model PriceWatchBooking {
  id                  String     @id @default(cuid())
  priceWatchId        String     @map("price_watch_id")
  priceWatch          PriceWatch @relation(fields: [priceWatchId], references: [id], onDelete: Cascade)
  bookingId           String     @unique @map("booking_id")
  booking             Booking    @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  dateFlexibilityDays Int        @default(0) @map("date_flexibility_days")
  cashThreshold       Decimal?   @map("cash_threshold") @db.Decimal(10, 2)
  awardThreshold      Int?       @map("award_threshold")
  createdAt           DateTime   @default(now()) @map("created_at")

  @@map("price_watch_bookings")
}

model PriceSnapshot {
  id                           String              @id @default(cuid())
  priceWatchId                 String              @map("price_watch_id")
  priceWatch                   PriceWatch          @relation(fields: [priceWatchId], references: [id], onDelete: Cascade)
  checkIn                      DateTime            @map("check_in") @db.Date
  checkOut                     DateTime            @map("check_out") @db.Date
  lowestRefundableCashPrice    Decimal?            @map("lowest_refundable_cash_price") @db.Decimal(10, 2)
  lowestRefundableCashCurrency String              @default("USD") @map("lowest_refundable_cash_currency")
  lowestAwardPrice             Int?                @map("lowest_award_price")
  source                       String
  fetchedAt                    DateTime            @default(now()) @map("fetched_at")
  rooms                        PriceSnapshotRoom[]

  @@index([priceWatchId, fetchedAt])
  @@map("price_snapshots")
}

model PriceSnapshotRoom {
  id              String        @id @default(cuid())
  priceSnapshotId String        @map("price_snapshot_id")
  priceSnapshot   PriceSnapshot @relation(fields: [priceSnapshotId], references: [id], onDelete: Cascade)
  roomId          String        @map("room_id")
  roomName        String        @map("room_name")
  ratePlanCode    String        @map("rate_plan_code")
  ratePlanName    String        @map("rate_plan_name")
  cashPrice       Decimal?      @map("cash_price") @db.Decimal(10, 2)
  cashCurrency    String        @default("USD") @map("cash_currency")
  awardPrice      Int?          @map("award_price")
  isRefundable    Refundability @default(UNKNOWN) @map("is_refundable")
  isCorporate     Boolean       @default(false) @map("is_corporate")

  @@index([priceSnapshotId])
  @@map("price_snapshot_rooms")
}
